Algoritmo "Analisador de Valores"

var
  c, nulo: inteiro
  num, soma, media, div5, somaPar: real
inicio
  div5 <- 0
  nulo <- 0
  somaPar <- 0
  soma <- 0
  media <- 0
  c <- 0
    para c de 1 ate 5 faca
      escreval ("Digite o ",c,"o. Valor: ")
      leia (num)
      soma <- soma + num
      media <- soma / 5
        se (num mod 5 = 0) e (num <> 0) entao
          div5 <- div5 + 1
        fimse
          se (num mod 2 = 0) entao
            somaPar <- somaPar + num
          fimse
            se (num = 0) entao
              nulo <- nulo + 1
            fimse
    fimpara
    escreval ("A soma entre os valores e: ",soma)
    escreval ("A media entre os valores e: ",media)
    escreval ("Valores divisiveis por cinco: ",div5)
    escreval ("Valores nulos: ",nulo)
    escreval ("Soma dos valores pares: ",somaPar)
fimalgoritmo