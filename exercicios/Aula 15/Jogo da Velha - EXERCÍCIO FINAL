Algoritmo "Jogo da Velha"

Var
 m: vetor[1..3,1..3] de inteiro
 l,c,cont,x,o,xVenceu,casasVazias,xVencedor, oVencedor, empate, jogadaValida: inteiro
 resp: caractere

procedimento desenha_tabela()
inicio
  limpatela
  escreval ("+---+---+---+")
    para l de 1 ate 3 faca
      para c de 1 ate 3 faca
        escreva ("|")
          se (m[l,c] = 0) entao
            escreva (" X")
              senao
                se (m[l,c] = 11) entao
                  escreva (" O")
                    senao
                      escreva (m[l,c]:3)
                fimse
            fimse
      fimpara
        escreva ("|")
        escreval ()
        escreval ("+---+---+---+")
    fimpara
 fimprocedimento
inicio
