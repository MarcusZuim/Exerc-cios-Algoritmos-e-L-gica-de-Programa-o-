Algoritmo "Jogo da Velha"

Var
m: vetor[1..3,1..3] de caractere
l,c, n, x: inteiro
nCarac: caractere
Inicio
n <- 1
  para l de 1 ate 3 faca
    para c de 1 ate 3 faca
      nCarac <- numpcarac(n)
      m[l,c] <- nCarac
      n <- n + 1
    fimpara
  fimpara
  para l de 1 ate 3 faca
    para c de 1 ate 3 faca
      escreva ("|" ,m[l,c], "|")
        se (caracpnum(m[l,c]) mod 3 = 0) entao
          escreval ()
          escreval ("+---+---+")
        fimse
    fimpara
  fimpara
  escreval ("Vai jogar o [X] em qual posição? ")
  leia (x)
Fimalgoritmo

