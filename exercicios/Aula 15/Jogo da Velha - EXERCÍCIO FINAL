  fimse
  se (m[1,3]=11) e (m[2,2]=11) e (m[3,1]=11) entao
    xVenceu <- 0
  fimse
  fimse

  ate (xVenceu = 0) ou (xVenceu = 1) ou (xVenceu = 3)
    se (xVenceu = 1) entao
      escreval ("O jogador [X] venceu!")
      xVencedor <- xVencedor + 1
    senao
      se (xVenceu = 0) entao
        escreval ("O jogador [O] venceu!")
        oVencedor <- oVencedor + 1
      senao
        escreval ("O jogo deu velha! (empatou)")
        empate <- empate + 1
      fimse
    fimse

  escreval ("Vezes em que o jogador [X] venceu: ",xVencedor)
  escreval ("Vezes em que o jogadoor [O] venceu: ",oVencedor)
  escreval ("Vezes em que deu empate: ",empate)
  escreval ("Deseja continuar? [S/N]")
  leia (resp)
  ate (maiusc(resp) = "N")
    se (xVencedor > oVencedor) entao
      escreval ("O jogador [X] venceu! ganhou ",xVencedor, " vezes!")
    senao
      se (xVencedor < oVencedor) entao
        escreval ("O jogador [O] venceu! ganhou ",oVencedor, " vezes!")
      senao
        escreval ("O jogo terminou empatado! Ambos venceram ",xVencedor, " vezes")
      fimse
    fimse
Fimalgoritmo