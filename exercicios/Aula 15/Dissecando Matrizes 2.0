Algoritmo "Dissecando Matrizes 2.0"

Var
m: vetor[1..100,1..100] de inteiro
l,c, resp, tamanhoMatriz: inteiro


Inicio
escreval ("Defina o tamanho da Matriz: ")
leia (tamanhoMatriz)
limpatela
aleatorio 1,30
  para l de 1 ate tamanhoMatriz faca
    para c de 1 ate tamanhoMatriz faca
      escreval ("Escreva o valor para a posicao [",l,",",c,"]: ")
      leia (m[l,c])
    fimpara
  fimpara
aleatorio off
limpatela
    repita
    escreval ()
    escreval ("MENU DE OPCOES ")
    escreval ("=======================")
    escreval ("[1] Mostrar a matriz: ")
    escreval ("[2] Diagonal Principal: ")
    escreval ("[3] Triangulo Inferior: ")
    escreval ("[4] Triangulo Superior: ")
    escreval ("[5] Sair")
    escreval ("=============== OPCAO: ")
    leia (resp)
    limpatela

    se (resp = 1) entao
      para l de 1 ate tamanhoMatriz faca
        para c de 1 ate tamanhoMatriz faca
          escreva (m[l,c]:3)
        fimpara
          escreval ()
      fimpara
    senao
      se (resp = 2) entao
        para l de 1 ate tamanhoMatriz faca
          para c de 1 ate tamanhoMatriz faca
            se (l = c) entao
              escreva ( m[l,c] )
            senao
              escreva (" 0":2)
            fimse
          fimpara
            escreval ()
        fimpara
        senao
          se (resp =3) entao
            para l de 1 ate tamanhoMatriz faca
              para c de 1 ate tamanhoMatriz faca
                se (l > c) entao
                  escreva (m[l,c])
                senao
                  escreva (" 0 ":2)
                fimse
              fimpara
                escreval ()
            fimpara
          senao
            se (resp = 4) entao
              para l de 1 ate tamanhoMatriz faca
                para c de 1 ate tamanhoMatriz faca
                  se (l < c) entao
                    escreva (m[l,c]:3)
                  senao
                    escreva (" 0 ")
                  fimse
                fimpara
                  escreval ()
              fimpara
            senao
              escreval ("Encerrando o programa...")
            fimse
          fimse
      fimse
    fimse
    ate (resp = 5)
Fimalgoritmo